{
  "expo": {
    "name": "Pushd",
    "slug": "pushd-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "pushd",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060C1B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fit.pushd.web",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.457233933936-je2apg0il7a9cm51ktrh2s8q7c5rmrad"
            ]
          }
        ],
        "NSPhotoLibraryUsageDescription": "Pushd uses your photo library to let you set a profile picture and attach progress photos to your workouts.",
        "NSCameraUsageDescription": "Pushd uses your camera to let you take a profile picture or capture workout progress photos.",
        "NSFaceIDUsageDescription": "Pushd uses Face ID to let you sign in quickly and securely without entering your password."
      },
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.associated-domains": [
          "webcredentials:pushd.fit"
        ]
      }
    },
    "android": {
      "package": "fit.pushd.app",
      "adaptiveIcon": {
        "backgroundColor": "#060C1B",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "pushd"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3B82F6",
          "sounds": []
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "bee118a9-6716-4aba-bd5e-4279c1e3adb8"
      },
      "router": {},
      "sentryDsn": "",
      "revenueCatApiKey": ""
    },
    "owner": "rameshyoha",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bee118a9-6716-4aba-bd5e-4279c1e3adb8"
    }
  }
}
