# Copy this file to .env.e2e and fill in credentials for a real pushd.fit test account.
# The .env.e2e file is gitignored and loaded automatically by e2e/global-setup.ts.
#
# Create a test account at https://pushd.fit/register, then add the credentials here.
# The account needs to have email verified before it can be used.

E2E_EMAIL=your-test-account@example.com
E2E_PASSWORD=YourPassword123!
